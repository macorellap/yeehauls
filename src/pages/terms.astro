---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';

const title = 'Terms of Service | Yee Hauls';
const description = 'The terms that govern use of the Yee Hauls LLC website.';
const effective = 'June 23, 2026';
---

<Layout title={title} description={description} path="/terms/">
  <section class="section">
    <div class="container" style="max-width: 760px;">
      <h1>Terms of Service</h1>
      <p style="font-size:0.9rem; color:var(--muted);">This is a starting template. For final legal review, consult a licensed attorney in {site.stateFull}.</p>
      <p><strong>Effective date:</strong> {effective}</p>

      <h2>Acceptance of terms</h2>
      <p>By using this website, you agree to these terms. If you do not agree, please do not use the site.</p>

      <h2>Our services</h2>
      <p>This site provides information about {site.legalName} dump trailer rental services. Any quotes or estimates are informational and are not a binding contract until confirmed directly with us.</p>

      <h2>SMS and text messaging terms</h2>
      <p>By providing your phone number and opting in through our quote form, you agree to receive text messages from {site.legalName} related to your quote and service, including scheduling, confirmations, and updates.</p>
      <ul>
        <li><strong>Message frequency:</strong> varies based on your inquiry and service.</li>
        <li><strong>Cost:</strong> message and data rates may apply, depending on your mobile carrier and plan.</li>
        <li><strong>Opt out:</strong> reply STOP at any time to stop receiving messages.</li>
        <li><strong>Help:</strong> reply HELP for assistance, or contact us at <a href={`tel:${site.phoneE164}`}>{site.phoneDisplay}</a> or <a href={`mailto:${site.email}`}>{site.email}</a>.</li>
        <li><strong>Consent:</strong> opting in is not a condition of purchase. Carriers are not liable for delayed or undelivered messages.</li>
      </ul>
      <p>Mobile information and text messaging opt-in consent are never shared with or sold to third parties or lead generators. See our <a href="/privacy/">Privacy Policy</a> for details.</p>

      <h2>Limitation of liability</h2>
      <p>Information on this site is provided "as is" without warranties of any kind. {site.legalName} is not liable for any damages arising from use of the site.</p>

      <h2>Intellectual property</h2>
      <p>The content, logo, and design of this site are owned by {site.legalName} and may not be reused without permission.</p>

      <h2>Governing law</h2>
      <p>These terms are governed by the laws of the State of {site.stateFull}.</p>

      <h2>Contact</h2>
      <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
    </div>
  </section>
</Layout>
