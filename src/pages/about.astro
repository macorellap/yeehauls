---
import Layout from '../layouts/Layout.astro';
import QuoteCta from '../components/QuoteCta.astro';
import { site } from '../data/site';
import { cities } from '../data/cities';

const title = 'About Yee Hauls | Local Dump Trailer Rental in the East Valley';
const description =
  'Yee Hauls is a local, owner-operated dump trailer rental business serving Gilbert, Chandler, Mesa, and Queen Creek, Arizona.';
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'About', item: `${site.url}/about/` },
  ],
};
---

<Layout title={title} description={description} path="/about/">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />

  <section class="hero" style="--hero-img: url('/images/hero-dump-trailer-rental-gilbert-az.jpg');">
    <div class="container hero__inner">
      <p class="eyebrow" style="color: var(--rust);">About Us</p>
      <h1>Local. Owner-Operated. Easy to Work With.</h1>
      <p class="subhead">Yee Hauls makes clearing out junk and debris simple for homeowners and contractors across the {site.metro}.</p>
    </div>
  </section>

  <section class="section">
    <div class="container" style="max-width: 800px;">
      <h2>Who we are</h2>
      <p class="lead" style="color:var(--ink);">
        Yee Hauls is a local, owner-operated dump trailer rental business based in {site.primaryCity}, {site.stateFull}. It started as a way to help out the community while providing for a family, and that is still the heart of it.
      </p>
      <p>
        As a Gilbert resident, the goal was simple: make junk and debris removal easy for the neighbors around here. Instead of renting an awkward roll-off or making trip after trip to the landfill, you get a trailer dropped at your door and we handle the haul-off. We treat every job like it is for someone down the street, because it usually is.
      </p>

      <h2 class="mt-2">How we work</h2>
      <p>
        We deliver a clean dump trailer to your home or job site, you load it on your own schedule, and we come back to pick it up and handle the dump run. No hourly clock, no surprise fees, and no landfill runs for you. You load it, we handle the rest.
      </p>

      <h2 class="mt-2">Licensed and insured</h2>
      <p>Yee Hauls carries a business license and business insurance. You get a professional you can count on showing up, handling your material, and taking care of disposal the right way.</p>

      <h2 class="mt-2">Where we work</h2>
      <p>We serve {cities.map((c) => c.name).join(', ')}, and the surrounding {site.metro}. Reach us at <a href={`tel:${site.phoneE164}`}>{site.phoneDisplay}</a> or <a href={`mailto:${site.email}`}>{site.email}</a>.</p>
    </div>
  </section>

  <QuoteCta />
</Layout>
