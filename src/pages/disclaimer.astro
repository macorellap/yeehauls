---
import Layout from '../layouts/Layout.astro';
import { site } from '../data/site';

const title = 'Disclaimer | Yee Hauls';
const description = 'General disclaimer for the Yee Hauls LLC website.';
---

<Layout title={title} description={description} path="/disclaimer/">
  <section class="section">
    <div class="container" style="max-width: 760px;">
      <h1>Disclaimer</h1>
      <p style="font-size:0.9rem; color:var(--muted);">This is a starting template. For final legal review, consult a licensed attorney in {site.stateFull}.</p>

      <p>The information on this website is provided for general informational purposes only. It does not guarantee any specific service outcome.</p>
      <p>Any pricing shown or discussed is an estimate only. Final pricing depends on the details of your job and is confirmed before service.</p>
      <p>For questions, contact {site.legalName} at <a href={`tel:${site.phoneE164}`}>{site.phoneDisplay}</a> or <a href={`mailto:${site.email}`}>{site.email}</a>.</p>
    </div>
  </section>
</Layout>
