---
import Layout from '../layouts/Layout.astro';
import QuoteCta from '../components/QuoteCta.astro';
import { site } from '../data/site';
import { cities } from '../data/cities';

const title = 'Contact Yee Hauls | Free Dump Trailer Quote in Gilbert, AZ';
const description =
  'Get a free dump trailer rental or hauling quote in Gilbert and the East Valley. Call (480) 876-5030 or send us a message.';
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: `${site.url}/contact/` },
  ],
};
---

<Layout title={title} description={description} path="/contact/">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumb)} />

  <section class="section">
    <div class="container" style="max-width: 760px; text-align:center;">
      <p class="eyebrow">Contact</p>
      <h1>Get a Free Quote</h1>
      <p class="lead">Call or text, or fill out the form below. We will get you a flat quote, usually the same day.</p>
      <div class="grid grid--3 mt-2">
        <div class="card">
          <h3>Call or Text</h3>
          <p><a href={`tel:${site.phoneE164}`}>{site.phoneDisplay}</a></p>
        </div>
        <div class="card">
          <h3>Email</h3>
          <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
        </div>
        <div class="card">
          <h3>Hours</h3>
          <p>{site.hours}</p>
        </div>
      </div>
      <p class="mt-2">We are a service-area business and come to you. Serving {cities.map((c) => c.name).join(', ')}, and the surrounding {site.metro}.</p>
    </div>
  </section>

  <QuoteCta heading="Tell Us About Your Job" blurb="Share a few details and we will follow up fast with a flat quote." />
</Layout>
