---
import { site } from '../data/site';
import { cities } from '../data/cities';

interface Props {
  heading?: string;
  blurb?: string;
}
const {
  heading = `Get a Free Dump Trailer Quote in ${site.primaryCity}`,
  blurb = 'Tell us what you are clearing out and where. We will get you a flat quote, usually same day.',
} = Astro.props;
---

<section class="section section--brown" id="quote">
  <div class="container">
    <div class="grid grid--2" style="gap:2.5rem; align-items:start;">
      <div>
        <p class="eyebrow" style="color: var(--rust);">Get Started</p>
        <h2>{heading}</h2>
        <p style="color: var(--cream);">{blurb}</p>
        <p style="color: var(--cream); margin-top:1.5rem;">
          Prefer to talk? Call or text<br />
          <a href={`tel:${site.phoneE164}`} style="color:#fff; font-family:var(--font-head); font-size:1.6rem;">{site.phoneDisplay}</a>
        </p>
      </div>

      <!-- Phase 1: posts to a Cloudflare Pages Function -> email/n8n. See functions/api/quote.ts -->
      <form class="quote-form" action="/api/quote" method="POST">
        <input type="hidden" name="_source" value={Astro.url.pathname} />
        <div>
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>
        <div>
          <label for="phone">Phone</label>
          <input id="phone" name="phone" type="tel" required autocomplete="tel" />
        </div>
        <div>
          <label for="email">Email</label>
          <input id="email" name="email" type="email" autocomplete="email" />
        </div>
        <div>
          <label for="city">City</label>
          <select id="city" name="city">
            {cities.map((c) => <option value={c.name}>{c.name}</option>)}
            <option value="Other">Other / nearby</option>
          </select>
        </div>
        <div>
          <label for="message">What are you clearing out?</label>
          <textarea id="message" name="message" rows="3" placeholder="e.g. garage cleanout, yard waste, remodel debris"></textarea>
        </div>
        <label class="consent">
          <input type="checkbox" name="sms_consent" value="yes" />
          <span>It is OK to text me about my quote. Message and data rates may apply.</span>
        </label>
        <button type="submit" class="btn btn--primary" style="justify-content:center;">Get My Free Quote</button>
      </form>
    </div>
  </div>
</section>
